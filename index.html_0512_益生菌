<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>湧健康 靈芝蟲草益生菌 - 專業導購最終版</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap');
        
        :root {
            --primary-green: #2d4c1e;
            --soft-green: #ccd5ae;
            --warm-beige: #fefae0;
            --earth-brown: #964b00;
            --text-main: #1a240d;
        }

        body { 
            font-family: 'Noto Sans TC', sans-serif; 
            color: var(--text-main);
            scroll-behavior: smooth;
            margin: 0;
            padding: 0;
            background-image: 
                linear-gradient(to bottom, rgba(255,255,255,0.15) 0%, rgba(74, 4, 4, 0.05) 100%), 
                url('https://i.postimg.cc/gkxqZzcj/Gemini-Generated-Image-sabsm3sabsm3sabs.png');
            background-attachment: fixed;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-color: var(--warm-beige);
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.95);
            backdrop-blur: 20px;
            border: 2px solid rgba(255, 255, 255, 0.6);
            border-radius: 2rem;
            box-shadow: 0 20px 60px rgba(0,0,0,0.08);
        }

        p, .content-text {
            font-size: 1.4rem !important;
            font-weight: 400 !important; 
            line-height: 1.8;
            color: #2d3436;
        }
        
        h1, h2, h3, .font-black {
            font-weight: 900 !important;
        }

        .new-top-banner {
            position: relative;
            width: 100%;
            height: auto; 
            display: flex;
            align-items: flex-end; 
            justify-content: center;
            overflow: hidden;
            background-color: #faf9f6;
        }
        @media (min-width: 768px) {
            .new-top-banner { height: 62vh; min-height: 480px; }
        }

        .new-top-banner .banner-img {
            width: 100%;
            height: auto;
            display: block;
            object-fit: contain; 
        }
        @media (min-width: 768px) {
            .new-top-banner .banner-img { height: 100%; object-fit: cover; }
        }

        /* 無縫跑馬燈 */
        .marquee-box {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            background-color: rgba(255, 255, 255, 0.85);
            backdrop-blur: 8px;
            padding: 10px 0;
            overflow: hidden;
            z-index: 20;
            border-top: 1px solid rgba(150, 75, 0, 0.1);
        }
        .marquee-content {
            display: flex;
            width: max-content;
            animation: marquee-seamless 45s linear infinite;
        }
        .marquee-text-block {
            display: flex;
            white-space: nowrap;
        }
        .marquee-text {
            padding-right: 150px;
            white-space: nowrap;
            color: var(--earth-brown);
            font-weight: 900;
            font-size: 1.1rem;
        }
        @media (min-width: 768px) {
            .marquee-text { font-size: 1.45rem; }
        }
        @keyframes marquee-seamless {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        .nav-circle {
            width: 110px; 
            height: 110px;
            border-radius: 50%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            background: white;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            border: 3px solid #f2f2f2;
            flex-shrink: 0;
        }
        @media (min-width: 768px) {
            .nav-circle { width: 195px; height: 195px; border-width: 6px; } 
        }
        .nav-circle.active {
            background: var(--primary-green);
            color: white !important;
            transform: scale(1.08);
            border-color: var(--primary-green);
        }
        .nav-circle i { font-size: 1.5rem; margin-bottom: 4px; }
        @media (min-width: 768px) {
            .nav-circle i { font-size: 3.2rem; margin-bottom: 12px; }
        }
        .nav-circle span { 
            font-size: 0.95rem; 
            font-weight: 500; 
            line-height: 1.2; 
            text-align: center; 
        }
        @media (min-width: 768px) {
            .nav-circle span { font-size: 1.4rem; }
        }

        .section-divider {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem 0;
        }
        .section-divider i { color: var(--primary-green); font-size: 1rem; margin: 0 15px; opacity: 0.5; }

        .manga-card {
            background: white;
            padding: 12px;
            border-radius: 1.5rem;
            box-shadow: 0 15px 45px rgba(0,0,0,0.07);
            border: 1px solid #f2f2f2;
            margin-bottom: 3rem;
        }
        @media (min-width: 768px) {
            .manga-card { padding: 20px; border-radius: 2.8rem; margin-bottom: 4.5rem; }
        }

        .floating-home {
            position: fixed;
            bottom: 25px;
            right: 20px;
            width: 65px;
            height: 65px;
            background: var(--earth-brown);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.25);
            z-index: 100;
        }

        .fade-in { animation: fadeInUp 0.8s ease-out forwards; }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>

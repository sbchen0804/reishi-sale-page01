    <footer class="py-16 md:py-24 bg-[#1a240d] text-stone-500 text-center border-t-8 border-[#2d4c1e]">
        <div class="container mx-auto px-10">
            <div class="text-white font-black text-3xl md:text-4xl mb-8 tracking-[0.4em] uppercase text-center">Ogift 湧健康</div>
            <p class="text-xs md:text-lg tracking-[0.5em] opacity-40 uppercase font-black text-center">© 2026 OGIFT AMITOS INC. | 您的健康專家</p>
        </div>
    </footer>

    <script>
        // [修正] Home 鍵精確校準：對準跑馬燈頂端，達成藍色 X 位置
        function goHomeFocus() {
            const marquee = document.getElementById('marquee-anchor');
            const nav = document.getElementById('top-nav');
            if(marquee && nav) {
                const targetPos = marquee.getBoundingClientRect().top + window.pageYOffset - nav.offsetHeight;
                window.scrollTo({ top: targetPos, behavior: 'smooth' });
            }
        }

        // [修正] 內容切換與定位同步，並讓影音區定位更靠上
        function switchSection(id) {
            if(id === 'video') {
                document.querySelectorAll('.display-content').forEach(el => el.classList.add('hidden'));
                document.getElementById('display-comic').classList.remove('hidden');
                document.querySelectorAll('.nav-circle').forEach(el => el.classList.remove('active'));
                document.getElementById('circle-video').classList.add('active');

                requestAnimationFrame(() => {
                    const videoTarget = document.getElementById('video-anchor');
                    const nav = document.getElementById('top-nav');
                    if(videoTarget && nav) {
                        // Offset 精細調整：navHeight - 40，減少空白感
                        const targetPos = videoTarget.getBoundingClientRect().top + window.pageYOffset - (nav.offsetHeight - 40);
                        window.scrollTo({ top: targetPos, behavior: 'smooth' });
                    }
                });
                return;
            }

            document.querySelectorAll('.display-content').forEach(el => el.classList.add('hidden'));
            const targetContent = document.getElementById('display-' + id);
            if(targetContent) targetContent.classList.remove('hidden');

            document.querySelectorAll('.nav-circle').forEach(el => el.classList.remove('active'));
            const targetCircle = document.getElementById('circle-' + id);
            if(targetCircle) targetCircle.classList.add('active');

            document.getElementById('interactive-content').scrollIntoView({ behavior: 'smooth' });
        }
    </script>
